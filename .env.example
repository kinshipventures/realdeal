# Supabase (required for app to run)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=your-project-id

# Auth bridge (set to false when using personal Supabase, not Lovable Cloud)
VITE_USE_LOVABLE_AUTH_BRIDGE=false

# Legacy - only needed for seed/migration scripts against Airtable
# VITE_AIRTABLE_TOKEN=pat...
# VITE_AIRTABLE_BASE_ID=app...
